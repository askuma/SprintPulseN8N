# ============================================================
# SprintPulse — Environment Variables (Track B: n8n)
# Copy to .env.local and fill in values. Never commit secrets.
# ============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Auth0 ---
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=...
AUTH0_CLIENT_SECRET=...
AUTH0_AUDIENCE=https://api.sprintpulse.io

# --- Database ---
DATABASE_URL=postgresql://sprintpulse:password@localhost:5432/sprintpulse
DATABASE_URL_TEST=postgresql://sprintpulse:password@localhost:5432/sprintpulse_test

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Internal API Key (shared between Gateway and n8n) ---
INTERNAL_API_KEY=change-me-to-a-strong-random-secret-min-32-chars

# --- AWS ---
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=reports@sprintpulse.io
AWS_S3_BUCKET=sprintpulse-reports
AWS_KMS_CMK_ARN=arn:aws:kms:us-east-1:123456789:key/...

# --- n8n (Track B only) ---
N8N_ENCRYPTION_KEY=change-me-to-32-char-aes-key-here
N8N_DB_POSTGRESDB_HOST=localhost
N8N_DB_POSTGRESDB_PORT=5432
N8N_DB_POSTGRESDB_DATABASE=n8n
N8N_DB_POSTGRESDB_USER=n8n
N8N_DB_POSTGRESDB_PASSWORD=n8n_password
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-strong-password
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_BASE_URL=http://localhost:5678

# --- Service URLs ---
AI_SERVICE_URL=http://localhost:8000
DELIVERY_SERVICE_URL=http://localhost:3002
GATEWAY_INTERNAL_URL=http://localhost:3001

# --- Feature Flags ---
ENABLE_CONFLUENCE_DELIVERY=false
ENABLE_BETA_FEATURES=false

# --- Observability ---
DATADOG_API_KEY=
DATADOG_ENV=development
LOG_LEVEL=debug
